# Auto-detect text files and perform LF normalization
* text=auto

# Force LF for source files
*.cs text eol=lf
*.ts text eol=lf
*.vue text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.sql text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.env text eol=lf

# Binary files — no line-ending processing
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.db binary
*.mdf binary
*.ldf binary
